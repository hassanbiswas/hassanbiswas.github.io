{
  "mcpServers": {
    "figma": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-figma"
      ],
      "env": {
        "FIGMA_PERSONAL_ACCESS_TOKEN": "YOUR_TOKEN_HERE"
      }
    },
    "hassanbiswas-docs": {
      "type": "sse",
      "url": "https://gitmcp.io/hassanbiswas/hassanbiswas.github.io"
    },
    "github-copilot": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/"
    }
  }
}
