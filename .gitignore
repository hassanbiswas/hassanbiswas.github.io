# --- System & Device (Oppo A53 / Android / Linux) ---
.DS_Store
Thumbs.db
.thumbnails/
.cache/
*.log
*.tmp
.studio/
.idea/
.vscode/
*.swp
*~

# --- Dependency Management ---
node_modules/
bower_components/
package-lock.json
yarn.lock
pnpm-lock.yaml

# --- Build & Distribution ---
# Keeps your root clean for your "Flattening Logic" in release.yml
dist/
build/
out/
.parcel-cache/
.next/
.nuxt/
bin/
obj/

# --- Environment & Security (Fallback Security) ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key
cert.ppk
auth.json

# --- Design Tools (Figma / Framer / Webflow) ---
*.fig
*.framer
.webflow/
.import/

# --- Automation & Archives ---
